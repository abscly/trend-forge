# Gemini API Key for analysis
# Get it from: https://aistudio.google.com/
GEMINI_API_KEY=""

# Discord Webhook URL for daily trend reports
# Create this in your Discord channel settings -> Integrations
DISCORD_WEBHOOK_URL=""

# GitHub API Token (Classic token with repo scope)
# Used to automatically commit reports to the Obsidian Vault via GitHub API
GITHUB_TOKEN=""

# Target Repository for Obsidian Vault (Format: Username/RepoName)
# Default is the user's Antigravity-workspace
VAULT_REPO="abscly/Antigravity-workspace"
